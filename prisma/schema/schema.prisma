generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ── Enum ──────────────────────────────────────────────────────────────────────────────
enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  BANNED
  DELETED
}

// ── User Schema ──────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  fullName        String
  email           String     @unique
  password        String
  phoneNumber     String?
  profileImage    String?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  isEmailVerified Boolean    @default(false)
  lastLoginAt     DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
