# Server Configuration
NODE_ENV=development
PORT=8082

# Database Configuration
# Supabase PostgreSQL (Replace with your credentials)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase Configuration
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_KEY="[YOUR-SERVICE-KEY]"

# JWT Configuration
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_RESET_PASSWORD_SECRET="your-super-secret-reset-key-min-32-chars"

# JWT Expiration Times
JWT_ACCESS_EXPIRATION_TIME="1d"
JWT_REFRESH_EXPIRATION_TIME="7d"
JWT_RESET_PASSWORD_EXPIRATION_TIME="30m"

# Authentication Settings
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=2

# Session Configuration
SESSION_SECRET="your-session-secret-key"
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=15

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# Email Configuration (Gmail Example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Redis Configuration (Upstash Example)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Client/Frontend URLs
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
DEV_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Backend Configuration
BACKEND_IP=0.0.0.0

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
ENCRYPTION_KEY="your-encryption-key-32-chars"

# Logging Configuration
LOG_LEVEL=debug
ENABLE_FILE_LOGGING=true

# Pagination Configuration
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100
PAGINATION_DEFAULT_PAGE=1

